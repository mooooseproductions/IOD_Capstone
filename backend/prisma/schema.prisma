generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int          @id @default(autoincrement())
  email            String       @unique
  handle           String       @unique
  name             String
  password         String
  status           String       @default("active")
  role             String       @default("user")
  accountCreatedAt DateTime     @default(now())
  accountClosedAt  DateTime?
  brew             BrewRecord[]
}

model BrewRecord {
  id              Int               @id @default(autoincrement())
  name            String
  status          String            @default("planning")
  style           String?
  dateStarted     DateTime          @default(now())
  dateFinished    DateTime?
  originalGravity Decimal?
  finalGravity    Decimal?
  batchSize       Decimal
  userId          Int
  ingredient      BrewIngredient[]
  note            BrewNote[]
  user            User              @relation(fields: [userId], references: [id])
}

model BrewIngredient {
  id           Int        @id @default(autoincrement())
  amount       Decimal
  unit         String
  brewId       Int
  ingredientId Int
  brew         BrewRecord @relation(fields: [brewId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model BrewNote {
  id          Int        @id @default(autoincrement())
  dateCreated DateTime   @default(now())
  dateUpdated DateTime?
  content     String
  brewId      Int
  brew        BrewRecord @relation(fields: [brewId], references: [id])
}

model Ingredient {
  id              Int               @id @default(autoincrement())
  type            String
  name            String            @unique
  brewIngredient  BrewIngredient[]
}
