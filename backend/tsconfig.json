{
    "compilerOptions": {
      "types": ["node"],
      "target": "ES2020",
      "module": "Node16",
      "moduleResolution": "Node16",
      "rootDir": "./src",
      "outDir": "./dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "ignoreDeprecations": "6.0"
    },
    "include": ["src", "prisma/**/.ts"]
  }